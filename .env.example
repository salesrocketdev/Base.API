# =========================
# BASE.API Boilerplate - Environment Example
# =========================
# Copie este arquivo para `.env` e ajuste os valores conforme o ambiente.

# -------------------------
# Aplicacao
# -------------------------
ASPNETCORE_ENVIRONMENT=Development
DATABASE__APPLYMIGRATIONSONSTARTUP=true
EF_VALIDATE_PENDING_MODEL_CHANGES=false

# -------------------------
# Banco de dados
# -------------------------
# Essas variaveis so sao aplicadas automaticamente na primeira inicializacao do volume do PostgreSQL.
# Se voce alterar depois, recrie o volume `db-data` ou ajuste a senha do usuario manualmente.
POSTGRES_USER=base
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=base_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSL_MODE=Disable

# -------------------------
# JWT
# -------------------------
JWT__SECRETKEY=change_me_super_secret_key_with_32_chars_min
JWT__ISSUER=Boilerplate
JWT__AUDIENCE=Boilerplate
JWT__ACCESSTOKENEXPIRATIONMINUTES=15
JWT__REFRESHTOKENEXPIRATIONDAYS=7

# -------------------------
# Seguranca
# -------------------------
SECURITY__PASSWORDHASHING__TIMECOST=3
SECURITY__PASSWORDHASHING__MEMORYCOST=65536
SECURITY__PASSWORDHASHING__LANES=1
SECURITY__PASSWORDHASHING__THREADS=1
SECURITY__PASSWORDHASHING__HASHLENGTH=32
SECURITY__PASSWORDHASHING__SALTLENGTH=16
SECURITY__PASSWORDHASHING__PEPPER=change_me_password_pepper
SECURITY__PASSWORDRESET__PEPPER=change_me_reset_pepper

# -------------------------
# Seed
# -------------------------
SEED__ENABLED=false
SEED__SCENARIO=base
SEED__RESETBEFORESEED=false
SEED__ADMINEMAIL=admin@base.local
SEED__ADMINPASSWORD=
SEED__ADMINNAME=Administrator
SEED__LEARNEREMAIL=learner@base.local
SEED__LEARNERPASSWORD=
SEED__LEARNERNAME=Learner
SEED__COMPANYNAME=Boilerplate Demo

# -------------------------
# Email
# -------------------------
ZEPTOMAILSETTINGS__TOKEN=
ZEPTOMAILSETTINGS__FROMADDRESS=noreply@base.local
ZEPTOMAILSETTINGS__FROMNAME=Boilerplate

# -------------------------
# Logging / Seq
# -------------------------
LOGGING__SEQ__SERVERURL=http://seq:5341
LOGGING__SEQ__MINIMUMLEVEL=Information

# -------------------------
# Hangfire
# -------------------------
HANGFIRE__STORAGE=PostgreSql
HANGFIRE__CONNECTIONSTRING=
HANGFIRE__ENABLED=true
HANGFIRE__USEDASHBOARD=false

# -------------------------
# Redis
# -------------------------
REDIS__ENABLED=true
REDIS__CONNECTIONSTRING=redis:6379
REDIS__INSTANCENAME=boilerplate

# -------------------------
# FCM
# -------------------------
FCM__ENABLED=false
FCM__PROJECTID=
FCM__SERVICEACCOUNTJSON=
FCM__SERVICEACCOUNTPATH=
